{
  "name": "fullstack-integration",
  "displayName": "前后端全链路开发与测试",
  "version": "1.2.0",
  "description": "前后端联调检查、配置驱动代码质量检查、实际参数测试",
  "triggers": {
    "keywords": [
      "前后端联调",
      "数据流",
      "模块盘点",
      "功能检查",
      "接口测试",
      "前后端",
      "联调",
      "测试",
      "验证",
      "功能完整性",
      "关联功能"
    ],
    "patterns": [
      "检查.*数据流",
      "前后端.*",
      "模块盘点",
      "功能.*检查",
      "测试.*功能",
      "验证.*",
      ".*联调.*"
    ],
    "intentDetection": {
      "enabled": true,
      "contexts": [
        "用户请求检查前后端数据流",
        "用户需要验证功能完整性",
        "用户希望进行模块盘点",
        "用户要求检查功能关联性",
        "用户需要进行功能测试",
        "用户提到前后端联调问题"
      ]
    }
  },
  "autoInvoke": {
    "enabled": true,
    "priority": "high",
    "conditions": [
      "用户明确提到'前后端'、'联调'、'数据流'等关键词",
      "用户需要检查功能完整性",
      "用户请求模块盘点",
      "用户要求验证功能实现"
    ]
  },
  "validationPhrase": "我尊敬的主人",
  "tags": [
    "fullstack",
    "integration",
    "testing",
    "data-flow"
  ]
}
