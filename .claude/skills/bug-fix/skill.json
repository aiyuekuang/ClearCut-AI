{
  "name": "bug-fix",
  "displayName": "Bug修复专家",
  "version": "1.0.0",
  "description": "快速定位和修复各类bug，包括UI问题、逻辑错误、数据问题等",
  "triggers": {
    "keywords": [
      "bug",
      "问题",
      "修复",
      "不工作",
      "无法",
      "点不了",
      "失败",
      "错误",
      "异常",
      "崩溃",
      "卡顿",
      "慢",
      "不显示",
      "显示错误",
      "无法点击",
      "无法选择",
      "下拉菜单",
      "拖动",
      "覆盖",
      "遮挡"
    ],
    "patterns": [
      ".*点不了.*",
      ".*不工作.*",
      ".*无法.*",
      ".*失败.*",
      ".*错误.*",
      ".*问题.*",
      "修复.*",
      "解决.*",
      ".*bug.*",
      ".*不显示.*",
      ".*显示不.*"
    ],
    "intentDetection": {
      "enabled": true,
      "contexts": [
        "用户报告某个功能不工作",
        "用户说某个地方点不了",
        "用户描述UI显示异常",
        "用户提到下拉菜单、按钮等元素无法使用",
        "用户说有错误或异常",
        "用户请求修复某个问题"
      ]
    }
  },
  "autoInvoke": {
    "enabled": true,
    "priority": "high",
    "conditions": [
      "用户明确提到'点不了'、'不工作'、'无法'等问题关键词",
      "用户描述UI元素（下拉菜单、按钮等）无法交互",
      "用户报告bug或错误",
      "用户请求修复某个问题"
    ]
  },
  "validationPhrase": "Bug已锁定，正在修复",
  "tags": [
    "bug-fix",
    "debugging",
    "troubleshooting",
    "ui-fix"
  ]
}
